#!/bin/sh
# bingo-change-memory-hook

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
python_bin=${PYTHON:-python3}
hook_source_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
bingo_root=$(CDPATH= cd -- "$hook_source_dir/../.." && pwd)
memory_script="$bingo_root/bingo/core/change_memory.py"

"$python_bin" "$memory_script" \
  --cwd "$repo_root" --commit HEAD >/dev/null 2>&1 || true
